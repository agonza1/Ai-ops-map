# Public, non-secret browser configuration for GitHub Pages builds.
# Use either a thin serverless endpoint that writes to HubSpot/CRM, or HubSpot form IDs.
VITE_LEAD_CAPTURE_ENDPOINT=
VITE_HUBSPOT_PORTAL_ID=
VITE_HUBSPOT_FORM_ID=
VITE_HUBSPOT_SUBSCRIPTION_TYPE_ID=

# Optional event collector. The app also pushes to dataLayer, gtag, and Plausible when present.
VITE_ANALYTICS_ENDPOINT=

# Public meeting/scheduler URL shown only after lead capture succeeds.
VITE_SCHEDULER_URL=
